---
import BaseLayout from '../layouts/BaseLayout.astro';
import foliaIcon from '../assets/folia-icon.png';
import { products } from '../data/products';
import { author } from '../data/author';

const p = products.folia;
const base = import.meta.env.BASE_URL;

const repoUrl = p.repo;
const releasesUrl = `${repoUrl}/releases/latest`;

const features = [
  {
    title: '复杂 Markdown 稳定阅读',
    text: '长文档、HTML 片段、宽表格和混合排版可以保持清晰，不把复杂资料压成难以阅读的源码。',
  },
  {
    title: 'Markdown 所见即所得',
    text: '普通 Markdown 默认进入轻量编辑视图，源码模式仍可随时切回，适合阅读、修订和整理知识材料。',
  },
  {
    title: 'Word 纸张预览与导出',
    text: '导出前先看到接近 A4 的页面效果，再用内置或自定义 JSON 预设生成可交付的 .docx。',
  },
  {
    title: 'HTML 文章与演示预览',
    text: '可复制为公众号编辑器友好的 HTML，也能隔离运行自包含 HTML 演示文件。',
  },
];

const downloadOptions = [
  'macOS Apple Silicon: 选择 aarch64 或 arm64 安装包',
  'macOS Intel: 选择 x64 或 x86_64 安装包',
  'Windows: 选择 .exe 或 .msi 安装包',
];

const workflow = [
  '打开 Markdown、HTML 或拖拽文件进入窗口',
  '阅读复杂 Markdown，必要时切换源码或结构化编辑',
  '打开 Word 或 HTML 预览，确认输出效果',
  '导出 .docx 或复制 HTML 到目标编辑器',
];
---

<BaseLayout
  title={`${p.name} - ${p.tagline}`}
  description={p.summary}
  activeSection="folia"
>
  <section class="folia-hero" aria-labelledby="hero-title">
    <div class="folia-hero-inner">
      <a class="folia-hero-back" href={`${base}`}>← 返回 {author.name} 主页</a>
      <img class="folia-hero-icon" src={foliaIcon.src} width="86" height="86" alt="" />
      <p class="eyebrow">Markdown reader for demanding documents</p>
      <h1 id="hero-title">{p.name}</h1>
      <p class="folia-hero-tagline">{p.tagline}</p>
      <div class="folia-hero-actions" aria-label="主要操作">
        <a class="button button-primary" href={releasesUrl}>下载最新版</a>
        <a class="button button-secondary" href={repoUrl} target="_blank" rel="noreferrer">查看源码</a>
      </div>

      <div class="folia-hero-product" aria-hidden="true">
        <div class="app-window">
          <div class="app-toolbar">
            <span></span>
            <span></span>
            <span></span>
            <strong>项目复盘.md</strong>
          </div>
          <div class="app-body">
            <aside class="app-rail">
              <span></span>
              <span></span>
              <span></span>
            </aside>
            <div class="editor-pane">
              <p class="md-heading"># 项目复盘</p>
              <p>## 一、关键结论</p>
              <p>- 交付范围已确认</p>
              <p>- 后续问题进入清单</p>
              <p>## 二、资料整理</p>
              <p>请核对每份材料的来源、状态和下一步动作。</p>
            </div>
            <div class="paper-pane">
              <div class="paper">
                <h2>项目复盘</h2>
                <table>
                  <thead>
                    <tr>
                      <th>模块</th>
                      <th>材料</th>
                      <th>状态</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td rowspan="2">输入</td>
                      <td>访谈记录</td>
                      <td>已整理</td>
                    </tr>
                    <tr>
                      <td>参考资料</td>
                      <td>待复核</td>
                    </tr>
                    <tr>
                      <td>输出</td>
                      <td colspan="2">报告草稿、附件清单与后续任务</td>
                    </tr>
                  </tbody>
                </table>
                <blockquote>{p.name} 会尽量保持复杂 Markdown 的阅读结构和纸面版式一致。</blockquote>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-intro" aria-labelledby="intro-title">
    <div class="section-inner intro-grid">
      <div>
        <p class="section-kicker">为什么做 {p.name}</p>
        <h2 id="intro-title">Markdown 很轻，复杂资料却经常很重。</h2>
      </div>
      <p>
        {p.name} 重点解决知识工作里的两个断点：复杂 Markdown 在常见工具里容易变形，导出 Word 前又很难确认最终纸面效果。它把阅读、轻量编辑、纸张预览和导出放在一个克制的桌面窗口里。
      </p>
    </div>
  </section>

  <section class="section" id="features" aria-labelledby="features-title">
    <div class="section-inner">
      <p class="section-kicker">核心能力</p>
      <h2 id="features-title">为长文档和复杂表格保留耐心。</h2>
      <div class="feature-grid">
        {features.map((feature) => (
          <article class="feature-card">
            <h3>{feature.title}</h3>
            <p>{feature.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-workflow" aria-labelledby="workflow-title">
    <div class="section-inner workflow-grid">
      <div>
        <p class="section-kicker">使用流程</p>
        <h2 id="workflow-title">从打开文件到交付结果，只保留必要步骤。</h2>
      </div>
      <ol class="workflow-list">
        {workflow.map((item) => (
          <li>{item}</li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section" id="download" aria-labelledby="download-title">
    <div class="section-inner download-panel">
      <div>
        <p class="section-kicker">下载</p>
        <h2 id="download-title">从 GitHub Releases 获取最新版本。</h2>
        <p>
          当前版本尚未做 Apple Developer 公证。macOS 首次运行如果提示无法验证开发者，请参考 README 中的首次运行说明。
        </p>
      </div>
      <div class="download-actions">
        <a class="button button-primary" href={releasesUrl}>打开下载页</a>
        <a class="button button-secondary" href={`${repoUrl}#readme`} target="_blank" rel="noreferrer">阅读 README</a>
      </div>
      <ul class="download-list" aria-label="安装包选择说明">
        {downloadOptions.map((option) => (
          <li>{option}</li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .folia-hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: clamp(46px, 7vw, 82px) clamp(18px, 4vw, 56px) clamp(28px, 4vw, 42px);
    border-bottom: 1px solid var(--border);
    background: linear-gradient(180deg, var(--surface) 0%, var(--bg) 100%);
  }

  .folia-hero-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: min(1080px, 100%);
    margin: 0 auto;
  }

  .folia-hero-back {
    align-self: flex-start;
    margin-bottom: 18px;
    color: var(--muted);
    font-size: 13px;
  }

  .folia-hero-back:hover {
    color: var(--accent);
  }

  .folia-hero-icon {
    display: block;
    width: 86px;
    height: 86px;
    margin-bottom: 26px;
    border-radius: 18px;
    box-shadow: 0 12px 34px oklch(32% 0.035 60 / 14%);
  }

  .folia-hero-tagline {
    max-width: 660px;
    margin: 12px 0 0;
    color: oklch(28% 0.025 60);
    font-size: clamp(17px, 2.2vw, 23px);
    line-height: 1.72;
  }

  .folia-hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    margin-top: 30px;
  }

  .folia-hero-product {
    position: relative;
    z-index: 1;
    width: min(900px, 100%);
    max-height: 260px;
    margin-top: clamp(30px, 4vw, 44px);
    overflow: hidden;
  }

  .app-window {
    position: relative;
    width: 100%;
    min-width: 0;
    margin: 0 auto;
    border: 1px solid oklch(82% 0.018 75);
    border-radius: 8px;
    background: var(--surface);
    box-shadow: var(--shadow);
    transform: rotate(-0.7deg);
  }

  .app-toolbar {
    display: grid;
    grid-template-columns: 10px 10px 10px 1fr;
    gap: 8px;
    align-items: center;
    height: 42px;
    padding: 0 18px;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
  }

  .app-toolbar span {
    width: 10px;
    height: 10px;
    border: 1px solid var(--border);
    border-radius: 999px;
  }

  .app-toolbar strong {
    justify-self: center;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 400;
  }

  .app-body {
    display: grid;
    grid-template-columns: 38px minmax(220px, 0.9fr) minmax(360px, 1.25fr);
    min-height: 360px;
  }

  .app-rail {
    display: flex;
    flex-direction: column;
    gap: 14px;
    align-items: center;
    padding-top: 24px;
    border-right: 1px solid var(--border);
    background: var(--bg);
  }

  .app-rail span {
    width: 16px;
    height: 2px;
    background: oklch(72% 0.02 75);
  }

  .editor-pane {
    padding: 28px 24px;
    border-right: 1px solid var(--border);
    background: var(--bg);
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.8;
  }

  .editor-pane p {
    margin: 0 0 13px;
  }

  .editor-pane .md-heading {
    color: var(--accent-deep);
  }

  .paper-pane {
    display: grid;
    place-items: center;
    padding: 34px;
    background: oklch(93% 0.014 78);
  }

  .paper {
    width: min(360px, 100%);
    min-height: 320px;
    padding: 34px 32px;
    border: 1px solid oklch(86% 0.012 75);
    border-radius: 2px;
    background: white;
    box-shadow: 0 14px 42px oklch(30% 0.025 60 / 12%);
    color: var(--ink);
  }

  .paper h2 {
    margin: 0 0 18px;
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 400;
  }

  .paper table {
    width: 100%;
    border-collapse: collapse;
    font-size: 11px;
  }

  .paper th,
  .paper td {
    padding: 8px 9px;
    border: 1px solid oklch(82% 0.015 76);
    text-align: left;
    vertical-align: top;
  }

  .paper th {
    background: oklch(96% 0.01 78);
    color: var(--muted);
    font-weight: 500;
  }

  .paper blockquote {
    margin: 22px 0 0;
    padding: 0 0 0 12px;
    border-left: 2px solid var(--accent);
    color: var(--muted);
    font-size: 12px;
    line-height: 1.7;
  }

  /* Intro / features / workflow / download — reuse BaseLayout section styles */

  .intro-grid,
  .workflow-grid {
    display: grid;
    grid-template-columns: minmax(260px, 0.8fr) minmax(320px, 1fr);
    gap: clamp(32px, 7vw, 96px);
    align-items: start;
  }

  .intro-grid > p {
    margin: 36px 0 0;
    font-size: clamp(17px, 2vw, 21px);
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
    margin-top: 42px;
  }

  .feature-card {
    min-height: 250px;
    padding: 24px 22px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
  }

  .feature-card:nth-child(2) {
    border-top-color: var(--sage);
  }

  .feature-card:nth-child(3) {
    border-top-color: var(--accent);
  }

  .feature-card:nth-child(4) {
    border-top-color: var(--steel);
  }

  .feature-card h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 400;
    line-height: 1.2;
  }

  .feature-card p {
    margin: 18px 0 0;
    font-size: 14px;
  }

  .section-workflow {
    background: var(--surface-strong);
  }

  .workflow-list {
    display: grid;
    gap: 12px;
    margin: 8px 0 0;
    padding: 0;
    counter-reset: workflow;
    list-style: none;
  }

  .workflow-list li {
    display: grid;
    grid-template-columns: 42px 1fr;
    gap: 16px;
    align-items: center;
    min-height: 66px;
    padding: 14px 18px;
    border: 1px solid oklch(82% 0.018 76);
    border-radius: 8px;
    background: var(--bg);
    color: var(--ink);
    line-height: 1.7;
  }

  .workflow-list li::before {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--accent-deep);
    content: counter(workflow, decimal-leading-zero);
    counter-increment: workflow;
    font-family: var(--font-mono);
    font-size: 12px;
  }

  .download-panel {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 32px;
    align-items: start;
    padding: clamp(28px, 4vw, 42px);
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
  }

  .download-panel p {
    max-width: 660px;
  }

  .download-actions {
    justify-content: flex-end;
    margin-top: 0;
  }

  .download-list {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin: 6px 0 0;
    padding: 0;
    list-style: none;
  }

  .download-list li {
    min-height: 76px;
    padding: 16px 18px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg);
    color: var(--muted);
    line-height: 1.65;
  }

  @media (max-width: 980px) {
    .folia-hero-product {
      max-height: 220px;
    }

    .app-window {
      width: 780px;
      max-width: none;
      opacity: 0.78;
    }

    .feature-grid,
    .download-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .intro-grid,
    .workflow-grid,
    .download-panel {
      grid-template-columns: 1fr;
    }

    .download-actions {
      justify-content: flex-start;
    }
  }

  @media (max-width: 680px) {
    .folia-hero-product {
      max-height: 160px;
      margin-top: 40px;
    }

    .app-window {
      width: 640px;
      margin-left: 50%;
      opacity: 0.38;
      transform: translateX(-50%) rotate(-0.7deg);
    }

    .feature-grid,
    .download-list {
      grid-template-columns: 1fr;
    }

    .feature-card {
      min-height: 0;
    }
  }
</style>
