---
import FoliaPage from '../components/pages/FoliaPage.astro';
import { resolveLocale, localeFromPath } from '../i18n';
import type { Locale } from '../i18n/types';

const base = import.meta.env.BASE_URL;
const locale: Locale = resolveLocale(localeFromPath(Astro.url.pathname, base));
---
<FoliaPage locale={locale} />
