---
import BaseLayout from '../layouts/BaseLayout.astro';
import { products } from '../data/products';
import { author } from '../data/author';

const p = products.faropdf;
const base = import.meta.env.BASE_URL;

const repoUrl = p.repo;
const releasesUrl = `${repoUrl}/releases/latest`;

const features = [
  {
    title: '阅读与检索',
    text: 'PDF.js 加载、虚拟化渲染（只渲染可见页和邻近页）、4 种视图模式（连续 / 单页 / 双页 / 适合宽度）、8 项缩放预设 + 旋转、键盘翻页、缩略图、阅读位置本地恢复、按需全文索引与高亮。',
  },
  {
    title: '批注',
    text: '9 种批注类型（高亮 / 下划线 / 删除线 / 备注 / 文本框 / 矩形 / 箭头 / 手写 / 图章）+ 6 色色板 + 5 套图章模板 + 中文图章真实绘制（思源黑体 SC + pdf-lib fontkit 嵌入）+ sidecar 摘要导出。',
  },
  {
    title: '页面整理',
    text: 'pdf-lib 真实改写：旋转 / 删除 / 重排 + 多选与 shift+click 区间选择 + 删除前 RiskConfirmDialog + 占位 Undo + 默认输出 `*-organized.pdf`，绝不覆盖原始文件。',
  },
  {
    title: 'OCR / 扫描',
    text: 'OCR bridge 真实接入：本地 ocrmypdf + 云端 PaddleOCR / MinerU；任务队列持久化 + 启动回收；4 个 Tauri command；扫描预处理 lopdf 真实清洁；9 态质量检查（可检索页比例 / 关键词命中 / CER / 体积比 / 耗时）。',
  },
  {
    title: '导出',
    text: 'pdf-lib 改写 + 表单 / 批注 flatten 双策略 + 文字 / 图片水印 + Bates 编号 + 普通页码 + 证据图片 A4 编排 + 压缩 plan-only。',
  },
  {
    title: '表单签署',
    text: 'AcroForm 字段识别（text / dropdown / checkbox / radio）+ 填值 + 签名图片 + FormsPanel 浮层 + flatten 导出（单条失败封装为 `failed` 不中断后续）。',
  },
  {
    title: '法律材料友好',
    text: '为律师工作流量身打造，重点支持长卷宗、扫描件、证据材料、批注汇总、页面编号与签署交付；高风险操作另存为新 PDF，不覆盖原始文件。',
  },
  {
    title: '设置 + 自动更新',
    text: '默认保存目录 / OCR provider / 隐私确认 / API Key 脱敏；检查更新走 `tauri-plugin-updater` 9 态状态机；`autoUpdateCheck` 设置项可关闭自动检查（DEC-056）。',
  },
];

const downloadOptions = [
  'macOS Apple Silicon：选择 aarch64 / arm64 安装包',
  'macOS Intel：选择 x64 / x86_64 安装包',
  'Windows：选择 .exe 或 .msi 安装包',
];

const workflow = [
  '打开本地 PDF 或拖拽文件进入窗口',
  '阅读 / 批注 / 整理页面，OCR 模式处理扫描件',
  '填表 / 签名 / 批注 flatten，导出为新 PDF',
  '另存为 `*-delivery.pdf` / `*-organized.pdf` / `*-evidence-pack.pdf` 交付',
];
---

<BaseLayout
  title={`${p.name} - ${p.tagline}`}
  description={p.summary}
  activeSection="faropdf"
>
  <section class="faropdf-hero" aria-labelledby="hero-title">
    <div class="faropdf-hero-inner">
      <a class="faropdf-hero-back" href={`${base}`}>← 返回 {author.name} 主页</a>
      <div class="faropdf-hero-icon-frame">
        <img class="faropdf-hero-icon" src={`${base}${p.icon}`} width="120" height="120" alt={`${p.name} 图标`} />
      </div>
      <p class="eyebrow">PDF reader for legal materials · v0.1.0-alpha</p>
      <h1 id="hero-title">{p.name}</h1>
      <p class="faropdf-hero-tagline">{p.tagline}</p>
      <p class="faropdf-hero-summary">{p.summary}</p>
      <div class="faropdf-hero-actions" aria-label="主要操作">
        <a class="button button-primary" href={releasesUrl}>下载最新版</a>
        <a class="button button-secondary" href={repoUrl} target="_blank" rel="noreferrer">查看源码</a>
      </div>
    </div>
  </section>

  <section class="section section-intro" aria-labelledby="intro-title">
    <div class="section-inner intro-grid">
      <div>
        <p class="section-kicker">为什么做 {p.name}</p>
        <h2 id="intro-title">法律材料很多 PDF，PDF 阅读器却常常不替它们着想。</h2>
      </div>
      <p>
        {p.name} 起点是律师日常处理卷宗、证据、判决、合同和扫描件的真实痛点：打开慢、检索难、批注零散、OCR 结果靠碰运气、交付时还要再过一遍整理。{p.name} 把快读、批注、OCR、页面整理和签署放在一个克制的桌面窗口里，并把「高风险操作绝不覆盖原始 PDF」当作硬约束。
      </p>
    </div>
  </section>

  <section class="section" id="features" aria-labelledby="features-title">
    <div class="section-inner">
      <p class="section-kicker">核心能力</p>
      <h2 id="features-title">八条主线，覆盖法律 PDF 处理的常见动作。</h2>
      <div class="feature-grid">
        {features.map((feature) => (
          <article class="feature-card">
            <h3>{feature.title}</h3>
            <p>{feature.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-workflow" aria-labelledby="workflow-title">
    <div class="section-inner workflow-grid">
      <div>
        <p class="section-kicker">使用流程</p>
        <h2 id="workflow-title">从打开卷宗到交付结果，路径尽量短。</h2>
      </div>
      <ol class="workflow-list">
        {workflow.map((item) => (
          <li>{item}</li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section" id="download" aria-labelledby="download-title">
    <div class="section-inner download-panel">
      <div>
        <p class="section-kicker">下载</p>
        <h2 id="download-title">从 GitHub Releases 获取最新版本。</h2>
        <p>
          当前 0.1.0 仍处 alpha 阶段：全平台打包与自动更新流水线已就位（`docs/RELEASE.md`），但**尚未生成任何公开 release**。下面的安装包说明在首个 release 发布后即生效。
        </p>
        <p>
          macOS 首次运行如果提示「无法验证开发者」或「已损坏」，未来指引是把 `FaroPDF.app` 拖到「应用程序」后在终端执行 <code>xattr -dr com.apple.quarantine /Applications/FaroPDF.app</code>，具体步骤以 release 时 `docs/RELEASE.md` 为准。
        </p>
      </div>
      <div class="download-actions">
        <a class="button button-primary" href={releasesUrl}>打开下载页（待发布）</a>
        <a class="button button-secondary" href={`${repoUrl}#readme`} target="_blank" rel="noreferrer">阅读 README</a>
      </div>
      <ul class="download-list" aria-label="安装包选择说明">
        {downloadOptions.map((option) => (
          <li>{option}</li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .faropdf-hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: clamp(46px, 7vw, 82px) clamp(18px, 4vw, 56px) clamp(28px, 4vw, 42px);
    border-bottom: 1px solid var(--border);
    background: linear-gradient(180deg, var(--surface) 0%, var(--bg) 100%);
  }

  .faropdf-hero-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: min(820px, 100%);
    margin: 0 auto;
    text-align: center;
  }

  .faropdf-hero-back {
    align-self: flex-start;
    margin-bottom: 18px;
    color: var(--muted);
    font-size: 13px;
  }

  .faropdf-hero-back:hover {
    color: var(--accent);
  }

  .faropdf-hero-icon-frame {
    display: grid;
    place-items: center;
    width: 132px;
    height: 132px;
    margin-bottom: 22px;
    border-radius: 28px;
    background: var(--surface);
    box-shadow: 0 14px 38px oklch(32% 0.035 60 / 14%);
  }

  .faropdf-hero-icon {
    display: block;
    width: 96px;
    height: 96px;
  }

  .faropdf-hero-tagline {
    max-width: 640px;
    margin: 16px 0 0;
    color: var(--accent-deep);
    font-family: var(--font-display);
    font-size: clamp(18px, 2.4vw, 24px);
    font-weight: 400;
  }

  .faropdf-hero-summary {
    max-width: 580px;
    margin: 22px 0 0;
    color: oklch(28% 0.025 60);
    font-size: clamp(15px, 1.8vw, 18px);
    line-height: 1.7;
  }

  .faropdf-hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    margin-top: 30px;
  }

  /* Intro */

  .intro-grid {
    display: grid;
    grid-template-columns: minmax(260px, 0.8fr) minmax(320px, 1fr);
    gap: clamp(32px, 7vw, 96px);
    align-items: start;
  }

  .intro-grid > p {
    margin: 36px 0 0;
    font-size: clamp(17px, 2vw, 21px);
  }

  /* Features */

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
    margin-top: 42px;
  }

  .feature-card {
    min-height: 250px;
    padding: 24px 22px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
  }

  .feature-card:nth-child(2) {
    border-top-color: var(--sage);
  }

  .feature-card:nth-child(3) {
    border-top-color: var(--accent);
  }

  .feature-card:nth-child(4) {
    border-top-color: var(--steel);
  }

  .feature-card h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 400;
    line-height: 1.2;
  }

  .feature-card p {
    margin: 14px 0 0;
    font-size: 13px;
    line-height: 1.65;
  }

  .section-workflow {
    background: var(--surface-strong);
  }

  /* Workflow */

  .workflow-grid {
    display: grid;
    grid-template-columns: minmax(260px, 0.8fr) minmax(320px, 1fr);
    gap: clamp(32px, 7vw, 96px);
    align-items: start;
  }

  .workflow-list {
    display: grid;
    gap: 12px;
    margin: 8px 0 0;
    padding: 0;
    counter-reset: workflow;
    list-style: none;
  }

  .workflow-list li {
    display: grid;
    grid-template-columns: 42px 1fr;
    gap: 16px;
    align-items: center;
    min-height: 66px;
    padding: 14px 18px;
    border: 1px solid oklch(82% 0.018 76);
    border-radius: 8px;
    background: var(--bg);
    color: var(--ink);
    line-height: 1.7;
  }

  .workflow-list li::before {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--accent-deep);
    content: counter(workflow, decimal-leading-zero);
    counter-increment: workflow;
    font-family: var(--font-mono);
    font-size: 12px;
  }

  /* Download */

  .download-panel {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 32px;
    align-items: start;
    padding: clamp(28px, 4vw, 42px);
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
  }

  .download-panel p {
    max-width: 660px;
  }

  .download-panel code {
    padding: 1px 6px;
    border-radius: 3px;
    background: var(--surface-strong);
    font-family: var(--font-mono);
    font-size: 0.9em;
  }

  .download-actions {
    justify-content: flex-end;
    margin-top: 0;
  }

  .download-list {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin: 6px 0 0;
    padding: 0;
    list-style: none;
  }

  .download-list li {
    min-height: 76px;
    padding: 16px 18px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg);
    color: var(--muted);
    line-height: 1.65;
  }

  /* Responsive */

  @media (max-width: 980px) {
    .feature-grid,
    .download-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .intro-grid,
    .workflow-grid,
    .download-panel {
      grid-template-columns: 1fr;
    }

    .download-actions {
      justify-content: flex-start;
    }
  }

  @media (max-width: 680px) {
    .feature-grid,
    .download-list {
      grid-template-columns: 1fr;
    }

    .feature-card {
      min-height: 0;
    }

    .faropdf-hero-icon-frame {
      width: 100px;
      height: 100px;
    }

    .faropdf-hero-icon {
      width: 76px;
      height: 76px;
    }
  }
</style>
