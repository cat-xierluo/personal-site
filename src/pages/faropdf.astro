---
import BaseLayout from '../layouts/BaseLayout.astro';
import { products } from '../data/products';
import { author } from '../data/author';

const p = products.faropdf;
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title={`${p.name} — ${p.tagline}`}
  description={p.summary}
  activeSection="faropdf"
>
  <section class="product-hero" aria-labelledby="product-title">
    <div class="product-hero__inner">
      <a class="product-hero__back" href={`${base}`}>← 返回 {author.name} 主页</a>
      <img class="product-hero__icon" src={`${base}${p.icon}`} width="120" height="120" alt={`${p.name} 图标`} />
      <p class="eyebrow">{p.name} · 产品页</p>
      <h1 id="product-title">{p.name}</h1>
      <p class="product-hero__tagline">{p.tagline}</p>
      <p class="product-hero__summary">{p.summary}</p>
      <div class="product-hero__actions">
        <a class="button button-primary" href={p.repo} target="_blank" rel="noreferrer">查看源码（GitHub）</a>
        <a class="button button-secondary" href={`${base}folia/`}>了解 Folia →</a>
      </div>
    </div>
  </section>

  <section class="section section-features" aria-labelledby="features-title">
    <div class="section-inner">
      <p class="section-kicker">核心能力</p>
      <h2 id="features-title">快读 · 检索 · 批注 · OCR · 表单签署</h2>
      <div class="features-list">
        <article class="feature-row">
          <h3>法律材料友好</h3>
          <p>为律师工作流量身打造，重点支持长卷宗、扫描件、证据材料、批注汇总和页面编号。</p>
        </article>
        <article class="feature-row">
          <h3>快读与全文本搜索</h3>
          <p>PDF.js 加载、虚拟化渲染、4 种视图模式、缩放与旋转、键盘翻页、按需缩略图、按需全文索引与高亮。</p>
        </article>
        <article class="feature-row">
          <h3>9 种批注 + 中文图章</h3>
          <p>高亮/下划线/备注/文本框/矩形/箭头/手写/图章，中文图章用思源黑体 SC 真实绘制，sidecar 摘要导出 Markdown / HTML。</p>
        </article>
        <article class="feature-row">
          <h3>OCR / 扫描预处理</h3>
          <p>本地 ocrmypdf + 云端 PaddleOCR / MinerU 双层 PDF 落地，扫描件 lopdf 清洁、9 态质量检查与持久化任务队列。</p>
        </article>
        <article class="feature-row">
          <h3>表单填写与签署</h3>
          <p>AcroForm 字段识别、签名图片、勾选 / 叉号 / 日期、批注 / 表单 flatten 导出。</p>
        </article>
        <article class="feature-row">
          <h3>导出 / 法律材料整理</h3>
          <p>pdf-lib 真实改写 + 文字 / 图片水印 + Bates 编号 + 普通页码 + 证据图片 A4 编排 + 压缩 plan-only。</p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .product-hero {
    padding: clamp(40px, 6vw, 80px) clamp(18px, 4vw, 56px) clamp(32px, 4vw, 56px);
    border-bottom: 1px solid var(--border);
    background: linear-gradient(180deg, var(--surface) 0%, var(--bg) 100%);
  }

  .product-hero__inner {
    position: relative;
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }

  .product-hero__back {
    display: inline-block;
    margin-bottom: 18px;
    color: var(--muted);
    font-size: 13px;
  }

  .product-hero__back:hover {
    color: var(--accent);
  }

  .product-hero__icon {
    display: block;
    width: 120px;
    height: 120px;
    margin: 0 auto 20px;
    border-radius: 26px;
    box-shadow: 0 14px 38px oklch(28% 0.035 60 / 14%);
  }

  .product-hero__tagline {
    margin: 14px 0 0;
    color: var(--accent-deep);
    font-family: var(--font-display);
    font-size: clamp(18px, 2.4vw, 24px);
    font-weight: 400;
  }

  .product-hero__summary {
    max-width: 580px;
    margin: 22px auto 0;
    color: oklch(28% 0.025 60);
    font-size: clamp(15px, 1.8vw, 18px);
    line-height: 1.7;
  }

  .product-hero__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    margin-top: 32px;
  }

  .features-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-top: 36px;
  }

  .feature-row {
    padding: 22px 26px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
  }

  .feature-row h3 {
    margin: 0 0 10px;
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 400;
  }

  .feature-row p {
    margin: 0;
    color: var(--muted);
    font-size: 15px;
    line-height: 1.7;
  }

  @media (max-width: 980px) {
    .features-list {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 680px) {
    .product-hero__icon {
      width: 88px;
      height: 88px;
    }
  }
</style>
