---
import FaroPdfPage from '../components/pages/FaroPdfPage.astro';
import { resolveLocale, localeFromPath } from '../i18n';
import type { Locale } from '../i18n/types';

const base = import.meta.env.BASE_URL;
const locale: Locale = resolveLocale(localeFromPath(Astro.url.pathname, base));
---
<FaroPdfPage locale={locale} />
