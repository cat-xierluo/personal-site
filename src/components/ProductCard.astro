---
import { products } from '../data/products';
import type { Locale, Messages } from '../i18n/types';

interface Props {
  slug: 'folia' | 'faropdf' | 'legal-skills' | 'agent-executor';
  locale: Locale;
  dict: Messages;
}

const { slug, locale, dict } = Astro.props;
const product = products[slug];
const base = import.meta.env.BASE_URL;
const detailHref = locale === 'en' ? `${base}en/${slug}/` : `${base}${slug}/`;
const tagline = locale === 'en' ? product.taglineEn : product.tagline;
const summary = locale === 'en' ? product.summaryEn : product.summary;
const iconAlt = locale === 'en' ? `${product.name} ${dict.productCard.iconAlt}` : `${product.name}${dict.productCard.iconAlt}`;
---

<article class={`product-card product-card--${product.accent}`}>
  <div class="product-card__icon">
    <img src={`${base}${product.icon}`} width="80" height="80" alt={iconAlt} />
  </div>
  <div class="product-card__body">
    <p class="product-card__eyebrow">{dict.productCard.eyebrow}</p>
    <h3 class="product-card__name">{product.name}</h3>
    <p class="product-card__tagline">{tagline}</p>
    <p class="product-card__summary">{summary}</p>
    <div class="product-card__actions">
      <a class="button button-primary" href={detailHref}>{dict.productCard.detailCta}</a>
      <a class="button button-secondary" href={product.repo} target="_blank" rel="noreferrer">{dict.productCard.sourceCta}</a>
    </div>
  </div>
</article>
