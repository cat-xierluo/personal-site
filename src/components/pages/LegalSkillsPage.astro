---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { products } from '../../data/products';
import { getDictionary } from '../../i18n';
import type { Locale, Messages } from '../../i18n/types';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict: Messages = getDictionary(locale);
const base = import.meta.env.BASE_URL;
const p = products['legal-skills'];

const tagline = locale === 'en' ? p.taglineEn : p.tagline;
const title = `${p.name} - ${tagline}`;
const description = locale === 'en' ? p.summaryEn : p.summary;
const backHref = locale === 'en' ? `${base}en/` : base;
const repoUrl = p.repo;
const readmeUrl = `${repoUrl}#readme`;
const introKicker = `${dict.legalSkills.introKickerPrefix} ${p.name}`;
---

<BaseLayout
  title={title}
  description={description}
  activeSection="legal-skills"
  locale={locale}
>
  <section class="legalskills-hero" aria-labelledby="hero-title">
    <div class="legalskills-hero-inner">
      <a class="back-link" href={backHref}>{dict.meta.backToHome}</a>
      <img class="legalskills-hero-icon" src={`${base}${p.icon}`} width="86" height="86" alt="" />
      <p class="eyebrow">{dict.legalSkills.heroEyebrow}</p>
      <h1 id="hero-title">{p.name}</h1>
      <p class="legalskills-hero-tagline">{tagline}</p>
      <div class="legalskills-hero-actions" aria-label={dict.legalSkills.heroPrimaryCta}>
        <a class="button button-primary" href="#features">{dict.legalSkills.heroPrimaryCta}</a>
        <a class="button button-secondary" href={repoUrl} target="_blank" rel="noreferrer">{dict.legalSkills.heroSecondaryCta}</a>
      </div>
    </div>
  </section>

  <section class="section section-intro" aria-labelledby="intro-title">
    <div class="section-inner intro-grid">
      <div>
        <p class="section-kicker">{introKicker}</p>
        <h2 id="intro-title">{dict.legalSkills.introTitle}</h2>
      </div>
      <p>{dict.legalSkills.introBody}</p>
    </div>
  </section>

  <section class="section" id="features" aria-labelledby="features-title">
    <div class="section-inner">
      <p class="section-kicker">{dict.legalSkills.featuresKicker}</p>
      <h2 id="features-title">{dict.legalSkills.featuresTitle}</h2>
      {dict.legalSkills.features.map((group) => (
        <div class="skill-group" data-group={group.key}>
          <h3 class="skill-group__title">{group.title}</h3>
          <div class="skill-group__grid">
            {group.items.map((item) => (
              <a
                class="skill-card"
                href={item.url}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${dict.legalSkills.featureCardVisitAria}: ${item.title}`}
              >
                <span class="skill-card__corner" aria-hidden="true">↗</span>
                <h4 class="skill-card__title">{item.title}</h4>
                <p class="skill-card__text">{item.text}</p>
                <span class="skill-card__cta">{dict.legalSkills.featureCardViewRepo} →</span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="section section-workflow" aria-labelledby="workflow-title">
    <div class="section-inner workflow-grid">
      <div>
        <p class="section-kicker">{dict.legalSkills.workflowKicker}</p>
        <h2 id="workflow-title">{dict.legalSkills.workflowTitle}</h2>
      </div>
      <ol class="workflow-list">
        {dict.legalSkills.workflow.map((item) => (
          <li>{item}</li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section" id="download" aria-labelledby="download-title">
    <div class="section-inner download-panel">
      <div>
        <p class="section-kicker">{dict.legalSkills.downloadKicker}</p>
        <h2 id="download-title">{dict.legalSkills.downloadTitle}</h2>
        <p>{dict.legalSkills.downloadBody}</p>
      </div>
      <div class="download-actions">
        <a class="button button-primary" href={repoUrl} target="_blank" rel="noreferrer">{dict.legalSkills.downloadPrimary}</a>
        <a class="button button-secondary" href={readmeUrl} target="_blank" rel="noreferrer">{dict.legalSkills.downloadSecondary}</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .legalskills-hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: clamp(64px, 9vw, 112px) clamp(18px, 4vw, 56px) clamp(48px, 6vw, 72px);
    border-bottom: 1px solid var(--border);
    background: linear-gradient(180deg, var(--surface) 0%, var(--bg) 100%);
  }

  .legalskills-hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: min(720px, 100%);
    margin: 0 auto;
    text-align: center;
  }

  .legalskills-hero-icon {
    width: 86px;
    height: 86px;
    border-radius: 18px;
    box-shadow: 0 6px 18px oklch(28% 0.035 60 / 14%);
  }

  .legalskills-hero-tagline {
    max-width: 660px;
    margin: 12px 0 0;
    color: oklch(28% 0.025 60);
    font-size: clamp(17px, 2.2vw, 23px);
    line-height: 1.72;
  }

  .legalskills-hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    margin-top: 32px;
  }

  /* Intro / workflow / download — uses shared classes from site.css */

  /* Skill groups + skill cards — page-specific (4 categories, clickable links, hover animation) */

  .skill-group {
    margin-top: 36px;
  }

  .skill-group__title {
    margin: 0 0 18px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
    color: var(--ink);
    font-family: var(--font-display);
    font-size: clamp(20px, 2.4vw, 26px);
    font-weight: 400;
    letter-spacing: -0.01em;
  }

  .skill-group__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  /* 4 groups × category-color cycle on the top border (sage / steel / royal / accent) */
  .skill-group[data-group="contentFetch"] .skill-card { border-top-color: var(--sage); }
  .skill-group[data-group="legalApp"]    .skill-card { border-top-color: var(--steel); }
  .skill-group[data-group="contentProcess"] .skill-card { border-top-color: var(--royal); }
  .skill-group[data-group="devTool"]    .skill-card { border-top-color: var(--accent); }

  .skill-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-height: 150px;
    padding: 18px 20px 16px;
    border: 1px solid var(--border);
    border-top: 3px solid var(--accent);
    border-radius: 8px;
    background: var(--surface);
    color: inherit;
    text-decoration: none;
    transition:
      transform 200ms ease,
      box-shadow 200ms ease,
      border-top-width 200ms ease;
  }

  .skill-card:hover,
  .skill-card:focus-visible {
    transform: translateY(-4px) scale(1.012);
    box-shadow: 0 16px 40px oklch(28% 0.035 60 / 18%);
    border-top-width: 5px;
  }

  .skill-card:hover .skill-card__corner,
  .skill-card:focus-visible .skill-card__corner {
    transform: translate(2px, -2px);
    color: var(--accent-deep);
  }

  .skill-card:hover .skill-card__cta,
  .skill-card:focus-visible .skill-card__cta {
    color: var(--accent-deep);
  }

  .skill-card__corner {
    position: absolute;
    top: 12px;
    right: 14px;
    color: var(--muted);
    font-size: 16px;
    line-height: 1;
    transition: transform 200ms ease, color 200ms ease;
  }

  .skill-card__title {
    margin: 0;
    padding-right: 22px;
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 500;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .skill-card__text {
    margin: 0;
    flex: 1 0 auto;
    color: var(--muted);
    font-size: 13px;
    line-height: 1.55;
  }

  .skill-card__cta {
    margin: 0;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.02em;
    transition: color 200ms ease;
  }

  @media (max-width: 980px) {
    .skill-group__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 680px) {
    .skill-group__grid {
      grid-template-columns: 1fr;
    }

    .legalskills-hero-icon {
      width: 64px;
      height: 64px;
    }
  }
</style>
